generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── HR-Sense Native Models ───────────────────────────────────────────────────
// These are HR-specific tables that live in HR-Sense's own database.
// Employee/task/time data is fetched live from EverSense API.

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  headEsId  String?  // EverSense user ID of department head
  orgId     String   // EverSense org ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employees   EmployeeProfile[]
  leavePolicy LeavePolicy?

  @@map("departments")
}

model EmployeeProfile {
  id           String   @id @default(cuid())
  esUserId     String   @unique // EverSense User.id
  employeeCode String   @unique
  title        String
  baseSalary   Float    @default(0)
  ratePerHour  Float?   // optional manual override; if null, computed from baseSalary
  currency     String   @default("PHP")
  startDate    DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Government-mandated contributions (PHP amounts)
  sssNumber            String?
  sssContribution      Float   @default(0)
  philHealthNumber     String?
  philHealthContribution Float @default(0)
  pagIbigNumber        String?
  pagIbigContribution  Float   @default(0)

  // Health card / HMO
  hasHealthCard        Boolean @default(false)
  healthCardProvider   String?

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  leaveBalances LeaveBalance[]
  leaveRequests LeaveRequest[]
  payrollRecords PayrollRecord[]

  @@index([esUserId])
  @@map("employee_profiles")
}

// ─── Leave Management ─────────────────────────────────────────────────────────

enum LeaveType {
  ANNUAL
  SICK
  UNPAID
  MATERNITY
  PATERNITY
  BEREAVEMENT
  PERSONAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model LeavePolicy {
  id           String  @id @default(cuid())
  departmentId String  @unique
  annualDays   Int     @default(20)
  sickDays     Int     @default(10)
  unpaidDays   Int     @default(30)
  maternityDays Int    @default(90)
  paternityDays Int    @default(14)
  bereavementDays Int  @default(5)
  personalDays Int     @default(5)

  department Department @relation(fields: [departmentId], references: [id])

  @@map("leave_policies")
}

model LeaveBalance {
  id          String    @id @default(cuid())
  year        Int
  type        LeaveType
  entitled    Int
  used        Int       @default(0)
  remaining   Int

  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, year, type])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String      @id @default(cuid())
  type        LeaveType
  status      LeaveStatus @default(PENDING)
  startDate   DateTime
  endDate     DateTime
  days        Int
  reason      String      @db.Text
  approvedBy  String?     // EverSense user ID of approver
  approvedAt  DateTime?
  rejectedBy  String?
  rejectedAt  DateTime?
  notes       String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
  @@index([startDate, endDate])
  @@map("leave_requests")
}

// ─── Payroll ──────────────────────────────────────────────────────────────────

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
}

model PayrollRecord {
  id            String        @id @default(cuid())
  period        String        // "2026-02"
  baseSalary    Float
  overtimePay   Float         @default(0)
  bonus         Float         @default(0)
  deductions    Float         @default(0)
  taxAmount     Float         @default(0)
  netPay        Float
  hoursWorked   Float
  overtimeHours Float         @default(0)
  status        PayrollStatus @default(DRAFT)
  paidAt        DateTime?
  notes         String?       @db.Text
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Snapshot from EverSense at time of processing
  esHoursLogged  Float        @default(0)
  esTasksCompleted Int        @default(0)

  employeeId  String
  employee    EmployeeProfile @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, period])
  @@index([period])
  @@index([status])
  @@map("payroll_records")
}

// ─── EverSense Synced Leaves (local copy written on approve) ─────────────────
// Mirrors the `leaves` table from EverSense so HR-Sense can query it without
// an external API call.  Written by the approve handler; read by the Leave page.

model Leave {
  id         String    @id @db.VarChar(191)
  userId     String    @db.VarChar(36)   // EverSense user ID
  orgId      String    @db.VarChar(191)  // EverSense org ID
  type       String    @db.VarChar(50)
  status     String    @default("APPROVED") @db.VarChar(20)
  startDate  DateTime
  endDate    DateTime
  days       Int
  reason     String?   @db.Text
  approvedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([userId, startDate])
  @@map("leaves")
}

// ─── EverSense Read-Only Models (shared database) ────────────────────────────
// These tables are owned/managed by EverSense. HR-Sense only reads them.
// Never run `prisma db push` for these — use `prisma generate` only.

model EsUser {
  id        String  @id @db.VarChar(36)
  email     String  @unique @db.VarChar(255)
  name      String? @db.VarChar(255)
  image     String? @db.VarChar(255)
  createdAt DateTime? @default(now()) @db.Timestamp(0)

  @@map("User")
}

model EsMembership {
  id     String @id
  userId String
  orgId  String
  role   String

  @@index([orgId])
  @@index([userId])
  @@map("memberships")
}

model EsAttendanceLog {
  id            String    @id @db.VarChar(50)
  userId        String    @db.VarChar(36)
  orgId         String    @db.VarChar(191)
  timeIn        DateTime
  timeOut       DateTime?
  duration      Int       @default(0)
  breakDuration Int       @default(0)
  date          String    @db.VarChar(10)
  createdAt     DateTime  @default(now())

  @@index([userId])
  @@index([orgId])
  @@map("attendance_logs")
}

model EsMacroTask {
  id             String    @id @db.VarChar(50)
  title          String    @db.VarChar(500)
  userId         String    @db.VarChar(36)
  orgId          String
  status         String    @default("not_started") @db.VarChar(20)
  priority       String    @default("Medium") @db.VarChar(10)
  actualHours    Decimal   @default(0.00) @db.Decimal(5, 2)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt

  @@index([userId, status])
  @@index([orgId])
  @@map("macro_tasks")
}

model EsTimeLog {
  id        String    @id @db.VarChar(50)
  taskId    String?   @db.VarChar(50)
  userId    String    @db.VarChar(36)
  orgId     String
  begin     DateTime
  end       DateTime?
  duration  Int       @default(0)
  category  String    @default("work") @db.VarChar(20)
  createdAt DateTime  @default(now())

  @@index([userId, begin])
  @@index([orgId])
  @@map("time_logs")
}

// ─── HR Settings ─────────────────────────────────────────────────────────────

model HrSettings {
  id                String  @id @default(cuid())
  orgId             String  @unique // EverSense org ID this HR instance manages
  eversenseApiUrl   String
  overtimeThreshold Int     @default(40) // weekly hours before OT
  workingHoursPerDay Int    @default(8)
  currency          String  @default("USD")
  fiscalYearStart   Int     @default(1) // month (1=January)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("hr_settings")
}
