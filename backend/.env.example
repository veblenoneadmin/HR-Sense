# ─── Database (Railway MySQL) ─────────────────────────────────────────────────
DATABASE_URL="mysql://user:password@host:3306/hr_sense"

# ─── EverSense Integration ────────────────────────────────────────────────────
EVERSENSE_API_URL="https://your-eversense-app.railway.app"
EVERSENSE_API_KEY=""          # If EverSense requires auth header
EVERSENSE_ORG_ID=""           # Your EverSense organization ID

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3001
FRONTEND_URL="https://your-hr-sense-app.railway.app"
